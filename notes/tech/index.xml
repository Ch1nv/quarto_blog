background-color: null;
font-style: inherit;">=</span> Path(<span class="ss" style="color: #20794D;
background-color: null;
font-style: inherit;">f"/kaggle/input/</span><span class="sc" style="color: #5E5E5E;
background-color: null;
font-style: inherit;">{</span>COMPETITION<span class="sc" style="color: #5E5E5E;
background-color: null;
font-style: inherit;">}</span><span class="ss" style="color: #20794D;
background-color: null;
font-style: inherit;">"</span>)</span>
<span id="cb20-7"><span class="cf" style="color: #003B4F;
